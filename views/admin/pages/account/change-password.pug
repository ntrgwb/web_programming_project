extends ../../layout/default.pug

block main
  .container.mt-4
    h2.mb-4 Đổi mật khẩu

    if messages.error
      .alert.alert-danger
        each item in messages.error
          div= item

    if messages.success
      .alert.alert-success
        each item in messages.success
          div= item

    form(action="/admin/account/change-password" method="POST")
      .form-group
        label(for="currentPassword") Mật khẩu hiện tại
        input.form-control(
          type="password"
          id="currentPassword"
          name="currentPassword"
          placeholder="Nhập mật khẩu hiện tại"
        )

      .form-group
        label(for="newPassword") Mật khẩu mới
        input.form-control(
          type="password"
          id="newPassword"
          name="newPassword"
          placeholder="Nhập mật khẩu mới"
        )

      .form-group
        label(for="confirmPassword") Xác nhận mật khẩu mới
        input.form-control(
          type="password"
          id="confirmPassword"
          name="confirmPassword"
          placeholder="Nhập lại mật khẩu mới"
        )

      button.btn.btn-primary(type="submit") Cập nhật mật khẩu