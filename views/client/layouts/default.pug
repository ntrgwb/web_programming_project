doctype html
html
  head
    title #{PageTitle}
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css")
    link(rel="stylesheet", href="/css/style.css")
    link(rel='preconnect' href='https://fonts.googleapis.com')
    link(rel='preconnect' href='https://fonts.gstatic.com' crossorigin='')
    link(href='https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Share+Tech+Mono&display=swap' rel='stylesheet')


  body
    video#bg-video(autoplay, loop, muted, playsinline)
      source(src="/uploads/matrix.mp4", type="video/mp4")
    
    //- Lớp phủ màu đen mờ (giúp chữ nổi bật lên trên nền video đang chuyển động)
    .overlay

    include ../partials/header.pug

    block main

    include ../partials/footer.pug

    script(src="https://cdn.jsdelivr.net/npm/jquery@3.5.1/dist/jquery.slim.min.js")
    script(src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.bundle.min.js")

    script(src="/js/script.js")