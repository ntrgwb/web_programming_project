extends ../../layouts/default.pug

block main
  .container.my-5
    h1.mb-4 Đơn hàng của tôi

    if orders.length > 0
      each order in orders
        .card.mb-4
          .card-body
            h4.mb-3 Đơn hàng

            p
              strong Họ tên:
              |  #{order.customerInfo.fullName}

            p
              strong Số điện thoại:
              |  #{order.customerInfo.phone}

            p
              strong Địa chỉ:
              |  #{order.customerInfo.address}

            p
              strong Trạng thái:
              if order.status == "pending"
                span.text-warning  Đang xử lý
              else if order.status == "confirmed"
                span.text-info  Đã xác nhận
              else if order.status == "shipping"
                span.text-primary  Đang giao
              else if order.status == "done"
                span.text-success  Đã giao
              else if order.status == "cancel"
                span.text-danger  Đã hủy
              else
                span  #{order.status}

            p
              strong Tổng tiền:
              |  #{order.totalPrice}$

            h5.mt-4 Sản phẩm đã mua
            table.table.table-bordered
              thead
                tr
                  th Tên sản phẩm
                  th Giá
                  th Số lượng
                  th Thành tiền
              tbody
                each item in order.products
                  tr
                    td= item.productInfo ? item.productInfo.title : "Sản phẩm đã bị xóa"
                    td= item.price + "$"
                    td= item.quantity
                    td= item.totalPrice + "$"
    else
      .alert.alert-info
        | Bạn chưa có đơn hàng nào.