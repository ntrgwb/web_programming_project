extends ../../layouts/default

block main
  h2(style="text-align:center") Chat với Admin

  #chat-container(style="width:400px;margin:auto;border:1px solid #ccc;padding:10px;border-radius:10px")

    // Khung hiển thị tin nhắn
    #chat-box(style="height:300px;overflow-y:scroll;border:1px solid #ddd;padding:10px;margin-bottom:10px;border-radius:10px")
      each msg in messages
        if msg.senderId == "USER_TEST"
          div(style="text-align:right;margin:5px")
            span(style="background:#4CAF50;color:white;padding:5px 10px;border-radius:10px;display:inline-block")
              | #{msg.content}
        else
          div(style="text-align:left;margin:5px")
            span(style="background:#eee;padding:5px 10px;border-radius:10px;display:inline-block")
              | #{msg.content}

    // Ô nhập + nút gửi
    div(style="display:flex;gap:5px")
      input(type="text" id="msg" placeholder="Nhập tin nhắn..." style="flex:1;padding:5px")
      button(onclick="sendMessage()") Gửi

  // SOCKET.IO
  script(src="/socket.io/socket.io.js")

  script.
    const socket = io();

    function sendMessage() {
      const input = document.getElementById("msg");
      if (!input.value.trim()) return;

      socket.emit("sendMessage", {
        senderId: "USER_TEST",
        receiverId: "ADMIN_ID",
        content: input.value
      });

      input.value = "";
    }

    socket.on("receiveMessage", (msg) => {
      const box = document.getElementById("chat-box");

      const div = document.createElement("div");
      div.style.margin = "5px";

      if (msg.senderId === "USER_TEST") {
        div.style.textAlign = "right";
        div.innerHTML = `<span style="background:#4CAF50;color:white;padding:5px 10px;border-radius:10px;display:inline-block">${msg.content}</span>`;
      } else {
        div.style.textAlign = "left";
        div.innerHTML = `<span style="background:#eee;padding:5px 10px;border-radius:10px;display:inline-block">${msg.content}</span>`;
      }

      box.appendChild(div);
      box.scrollTop = box.scrollHeight;
    });